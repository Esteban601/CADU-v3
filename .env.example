# Copia este archivo a .env y rellena los valores. NO subas .env al repo.

# Django
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DEBUG=True
# Forzar HTTPS (poner TRUE solo en producción; replica configure :production de app.rb)
SECURE_SSL_REDIRECT=False

# Monitoreo de errores (Sentry). Si se deja vacío, Sentry no se inicializa.
SENTRY_DSN=

# --- Formulario de boletín (POST /es/boletinsubscripcion) ---
# reCAPTCHA v3 (clave secreta del servidor)
RECAPTCHA_SECRET_KEY=

# Correo del aviso (Mailgun SMTP). Host/puerto tienen default; user/clave son secretos.
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Remitente y destinatario del aviso de suscripción (tienen default razonable)
NEWSLETTER_FROM=it@investorcloud.net
NEWSLETTER_TO=it@irstrat.com

# Firebase Realtime DB (suscriptores) por REST
FIREBASE_URL=https://iredge.firebaseio.com
# CAMBIO vs el Sinatra: token server-side para escribir con auth (cerrar reglas).
# Si se deja vacío, la escritura se hace sin auth y se loguea una advertencia.
FIREBASE_TOKEN=
