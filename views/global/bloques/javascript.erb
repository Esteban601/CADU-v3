<!--Validar email-->
<script type="text/javascript">

    function validaremail(formulario) {

        if (validateEmail(document.formulario.email.value) == false){

            <%= " $('#subscribir').popover({content: 'Dirección email errónea, rectifíquela por favor.'});" if I18n.locale == :es %>
            <%= " $('#subscribir').popover({content: 'Not a valid e-mail address, please rectify.'});" if I18n.locale == :en %>

            $('#subscribir').popover('show');
        }
        else {

            <%= "$('#subscribir').attr('data-content', 'Gracias por subscribirse a nuestras noticias.');" if I18n.locale == :es %>
            <%= "$('#subscribir').attr('data-content', 'Thanks for subscribing');" if I18n.locale == :en %>



            $('#subscribir').popover('show');

            setTimeout(continueExecution, 1500);
        }
    }


    function continueExecution()
    {
        document.formulario.submit();
    }

    function validateEmail(email) {
        var re = /^(([^<>()[\]\\.,;:\s@\"]+(\.[^<>()[\]\\.,;:\s@\"]+)*)|(\".+\"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        return re.test(email);
    }

</script>
<script type="text/javascript">

    $.ajax({
        url:'http://marktdaten.irstrat.com/intra/147.json?callback=callback',
        async: false,
        dataType: 'jsonp',
        jsonpCallback: 'jsonCallback',
        contentType: "application/json",
        success: function(json) {
//            precios = json.precios;
//            ipc = json.ipc;
            intradia = json.intradia;
            ticker_symbol = "CADUA";
            Dataticker(intradia);
//            fillData(precios,ipc,ticker_symbol);
            //            console.dir(json.sites);
        }

    });


    function Dataticker(intradia){
        volume = numberWithCommas(intradia["volume"])
        $('#price-ticker').html("$" + intradia["price"]);
        $('#change-ticker').html(intradia["change"]);
        $('#volume-ticker').html(volume);

        $('#range-ticker').html("$" +  intradia["min"]+" - "+ "$" + intradia["max"]);

//        $('#min-ticker').html(intradia["min"]);
//        $('#max-ticker').html(intradia["max"]);


        $('#date-ticker').html(intradia["date"]+", "+intradia["time"]+" EST");
        if(intradia["change"].indexOf("+") != -1){
            $('#arrow-change').html("▲");
        }
        else{
            $('#arrow-change').html("▼");
        }

    }

    function numberWithCommas(x) {
        return x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }
</script>

