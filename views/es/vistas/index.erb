                <a href="/#tab-33" role="tab" data-toggle="tab" class="c-font-16">RESIDENCIAL</a>
              </li>
              <li role="presentation">
                <a href="/#tab-32" role="tab" data-toggle="tab" class="c-font-16">MEDIO-RESIDENCIAL</a>
              </li>
              <li role="presentation">
                <a href="/#tab-31" role="tab" data-toggle="tab" class="c-font-16">MEDIO</a>
              </li>
              <li role="presentation">
