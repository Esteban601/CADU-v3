<% #listado de documentos
   @documents= [
       {:titulo => "Presentación Corporativa", :date => "2021-09", :link => @presentaciones_path + "Presentacion-Corporativa-Sep-2021.pdf"},
       #{:titulo => "Presentación Corporativa", :date => "2018-06", :link => @presentaciones_path + "Presentacion-Corporativa-2018.pdf"},
       #{:titulo => "Información para Inversionistas (NOV 2018)", :date => "2018-11", :link => @presentaciones_path +"Informacion-Inversionistas.pdf"},


   ]
%>

<div class="presentaciones">
  <table class="table">
    <thead>
    <tr>
      <th class="col-md-9">Documento</th>
      <th class="col-md-3">Fecha</th>
    </tr>
    </thead>
    <tbody>
    <% @documents.each do |document| %>
        <tr>
          <td><a target="_blank" href="<%= document[:link] %>"><%= document[:titulo] %></a></td>
          <td><%= document[:date] %></td>
        </tr>
    <% end %>
    </tbody>
  </table>
</div>
